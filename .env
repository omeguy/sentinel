# ======================================================
# Orchestrator DB (Docker internal network)
# ======================================================
DB_HOST=orchestrator-mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=orchestrator

DB_POOL_NAME=orch_pool
DB_POOL_SIZE=10
DB_CONNECT_TIMEOUT=10


# ======================================================
# Images
# ======================================================
BOT_IMAGE=omegatega/tracy:latest
NOVNC_IMAGE=omegatega/tracy-novnc:latest


# ======================================================
# Bot infra (Docker internal service names only)
# ======================================================
BOT_INFRA_NETWORK=tracy_bridge

BOT_REDIS_CONTAINER=tracy-redis
BOT_MYSQL_CONTAINER=tracy-mysql

BOT_INFRA_AUTOCREATE=1

BOT_REDIS_IMAGE=redis:7-alpine
BOT_REDIS_PORT=6379

BOT_MYSQL_IMAGE=mysql:8.0
BOT_MYSQL_ROOT_PASSWORD=root
BOT_MYSQL_DATABASE=bot_registry
BOT_MYSQL_PORT=3306


